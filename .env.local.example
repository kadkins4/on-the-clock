# Alpha suggestion box → Formspree. Copy this file to .env.local and fill in.
# Unset: suggestions are stashed in localStorage under "otc:suggestions".
# Create a form at https://formspree.io and paste its endpoint URL here.
VITE_FORMSPREE_ENDPOINT=

# Yahoo ADP source (optional). Register a Confidential Client app at
# https://developer.yahoo.com/apps/ (redirect https://localhost:8080, Fantasy
# Sports → Read), then run `npm run yahoo-auth` to fill these in automatically.
# See scripts/adp/README.md.
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REFRESH_TOKEN=
