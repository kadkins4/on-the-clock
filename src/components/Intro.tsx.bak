import { useEffect, useRef, useState } from "react";

const KEY = "otc:intro-seen";
const LINE1 = "You're now...";
const LINE2 = "On The Clock";

// Splash: typewriter reads "You're now... On The Clock", then a football
// wipes across to reveal the draft sheet. Plays once per browser session;
// click to skip. Placeholder polish.
export function Intro() {
  const [show, setShow] = useState(() => {
    try {
      return sessionStorage.getItem(KEY) !== "1";
    } catch {
      return true;
    }
  });
  const [typed1, setTyped1] = useState("");
  const [typed2, setTyped2] = useState("");
  const [phase, setPhase] = useState<"typing" | "wiping">("typing");
  const timer = useRef<number | undefined>(undefined);

  useEffect(() => {
    if (!show) return;
    let i = 0;
    let j = 0;
    const step = () => {
      if (i < LINE1.length) {
        i += 1;
        setTyped1(LINE1.slice(0, i));
        // longer beat on the trailing "..."
        const ch = LINE1[i - 1];
        timer.current = window.setTimeout(step, ch === "." ? 240 : 95);
      } else if (j < LINE2.length) {
        j += 1;
        setTyped2(LINE2.slice(0, j));
        timer.current = window.setTimeout(step, 115);
      } else {
        timer.current = window.setTimeout(() => setPhase("wiping"), 650);
      }
    };
    timer.current = window.setTimeout(step, 450);
    return () => window.clearTimeout(timer.current);
  }, [show]);

  function finish() {
    try {
      sessionStorage.setItem(KEY, "1");
    } catch {
      /* private mode — replays next session */
    }
    setShow(false);
  }

  function skip() {
    window.clearTimeout(timer.current);
    finish();
  }

  if (!show) return null;

  return (
    <div
      className={`otc-intro ${phase === "wiping" ? "wiping" : ""}`}
      onClick={skip}
      role="presentation"
    >
      <div
        className="otc-intro-panel"
        onAnimationEnd={phase === "wiping" ? finish : undefined}
      >
        <div className="otc-type">
          <div className="otc-type-1">{typed1}</div>
          <div className="otc-type-2">
            {typed2}
            {phase === "typing" && (
              <span className="otc-caret" aria-hidden="true" />
            )}
          </div>
        </div>
      </div>
      <span className="otc-football" aria-hidden="true">
        🏈
      </span>
    </div>
  );
}
